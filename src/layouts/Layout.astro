---
import { t, getAlternateLang, languages } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const tr = t(lang);
const alternateLang = getAlternateLang(lang);
const base = import.meta.env.BASE_URL;

// Current path without base and without lang prefix
const currentPath = Astro.url.pathname
  .replace(base.replace(/\/$/, ''), '')
  .replace(/^\/[a-z]{2}(\/|$)/, '/') || '/';

const alternatePath = `${base}${alternateLang}${currentPath === '/' ? '' : currentPath}`;
const pageTitle = title ? `${title} | Riku Yamamoto` : 'Riku Yamamoto | 山本 陸';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link rel="alternate" hreflang={alternateLang} href={alternatePath} />
    <script is:inline>
      // Dark mode: check localStorage or system preference
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-200">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur border-b border-gray-100 dark:border-gray-800">
      <nav class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={`${base}${lang}/`} class="font-semibold text-accent-600 dark:text-accent-400 hover:opacity-80 transition-opacity">
          {lang === 'en' ? 'Riku Yamamoto' : '山本 陸'}
        </a>
        <div class="flex items-center gap-1 sm:gap-4">
          <a href={`${base}${lang}/`} class="nav-link">{tr.nav.home}</a>
          <a href={`${base}${lang}/publications/`} class="nav-link">{tr.nav.publications}</a>
          <a href={`${base}${lang}/cv/`} class="nav-link">{tr.nav.cv}</a>

          <!-- Language toggle -->
          <a
            href={alternatePath}
            class="ml-2 px-2.5 py-1 text-xs font-medium rounded-full border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
            title={languages[alternateLang]}
          >
            {alternateLang === 'ja' ? '日本語' : 'EN'}
          </a>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="p-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
            </svg>
            <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-4 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 dark:border-gray-800 py-6 text-center text-sm text-gray-400 dark:text-gray-500">
      <p>© {new Date().getFullYear()} {lang === 'en' ? 'Riku Yamamoto' : '山本 陸'} · {tr.footer.rights}</p>
      <p class="mt-1">{tr.footer.builtWith}</p>
    </footer>

    <script>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const html = document.documentElement;
        if (html.classList.contains('dark')) {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      });
    </script>
  </body>
</html>

<style is:global>
  .nav-link {
    @apply text-sm text-gray-600 dark:text-gray-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors font-medium;
  }
</style>
